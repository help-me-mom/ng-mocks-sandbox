{
  "name": "ng-mocks-sandbox",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "A sandbox with guides and examples to play with ng-mocks",
  "keywords": [
    "angular",
    "ng-mocks",
    "mock",
    "mocking",
    "test",
    "testing",
    "sandbox",
    "playground"
  ],
  "scripts": {
    "npm": "npm",
    "ng": "ng",
    "start": "ng test",
    "serve": "ng serve --disable-host-check",
    "test": "ng test",
    "hooks:install": "husky",
    "prettier:repo": "prettier --loglevel warn -u -w .",
    "prettier:check": "prettier -u -c .",
    "ts:check": "tsc --noEmit"
  },
  "dependencies": {
    "@angular/animations": "21.2.11",
    "@angular/common": "21.2.11",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.11",
    "@angular/forms": "21.2.11",
    "@angular/platform-browser": "21.2.11",
    "@angular/platform-browser-dynamic": "21.2.11",
    "@angular/router": "21.2.11",
    "@types/jasmine": "6.0.0",
    "core-js": "3.49.0",
    "jasmine-core": "6.2.0",
    "ng-mocks": "14.15.2",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.9",
    "@angular/cli": "21.2.9",
    "@angular/compiler-cli": "21.2.11",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@types/jasmine": "6.0.0",
    "@types/node": "24.12.2",
    "husky": "9.1.7",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-ie-launcher": "1.0.0",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "karma-junit-reporter": "2.0.1",
    "npm": "11.14.0",
    "prettier": "3.8.3",
    "puppeteer": "24.43.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "npm": "11.14.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
